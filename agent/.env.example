TECHVSOC_AGENT_NAME=TechvSOC XDR Platform Agent
TECHVSOC_AGENT_BACKEND_URL=http://localhost:8000/api/v1
TECHVSOC_AGENT_TOKEN=replace-with-admin-or-analyst-jwt
TECHVSOC_AGENT_INTERVAL_SECONDS=30
TECHVSOC_AGENT_LOG_INTERVAL_SECONDS=60
TECHVSOC_AGENT_VERSION=1.0.0
TECHVSOC_AGENT_DEFAULT_LOG_SOURCE=endpoint-agent
TECHVSOC_AGENT_LOG_FILES=/var/log/syslog,/var/log/auth.log
TECHVSOC_AGENT_STATE_PATH=.agent-state.json
